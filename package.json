{
  "name": "vue-simple-props",
  "type": "module",
  "version": "0.6.4",
  "packageManager": "pnpm@11.15.1",
  "description": "Remove emits, slots, and attrs concepts in Vue.",
  "author": "Kevin Deng <sxzz@sxzz.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/sxzz",
  "homepage": "https://github.com/sxzz/vue-simple-props#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sxzz/vue-simple-props.git"
  },
  "bugs": {
    "url": "https://github.com/sxzz/vue-simple-props/issues"
  },
  "exports": {
    ".": {
      "dev": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsgo --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^8.0.0",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/test-utils": "^2.4.10",
    "bumpp": "^11.0.1",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.0",
    "tsdown-preset-sxzz": "^0.6.0",
    "typescript": "^7.0.0",
    "vitest": "^4.1.5",
    "vue": "^3.5.33"
  },
  "prettier": "@sxzz/prettier-config"
}
